<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textViewOrderHistoryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/order_history_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/textViewOrdersLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/placed_orders"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <ListView
        android:id="@+id/listViewOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp" />

    <TextView
        android:id="@+id/textViewDetailsLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/order_details"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5">

        <TextView
            android:id="@+id/textViewOrderDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_order_prompt"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="@android:color/white" />
    </ScrollView>

    <Button
        android:id="@+id/buttonCancelOrder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/button_cancel_order"
        android:layout_marginTop="16dp" />

</LinearLayout>
